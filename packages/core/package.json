{
  "name": "@mnemoai/core",
  "version": "1.2.0",
  "description": "Cognitive science-based AI memory framework — Weibull decay, triple-path retrieval, multi-backend storage",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./storage-adapter": {
      "import": "./dist/src/storage-adapter.js",
      "types": "./dist/src/storage-adapter.d.ts"
    },
    "./internals/*": {
      "import": "./dist/src/*.js",
      "types": "./dist/src/*.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai-memory",
    "long-term-memory",
    "vector-search",
    "bm25",
    "knowledge-graph",
    "hybrid-retrieval",
    "rerank",
    "weibull-decay",
    "cognitive-science",
    "rag",
    "agent-memory",
    "lancedb",
    "qdrant",
    "chroma",
    "pgvector"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Methux/mnemo.git"
  },
  "homepage": "https://m-nemo.ai",
  "bugs": {
    "url": "https://github.com/Methux/mnemo/issues"
  },
  "author": "Mnemo Contributors",
  "license": "MIT",
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@sinclair/typebox": "0.34.48",
    "openai": "^6.21.0"
  },
  "optionalDependencies": {
    "@qdrant/js-client-rest": "^1.12.0",
    "chromadb": "^1.9.0",
    "pg": "^8.13.0"
  },
  "mnemo": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build",
    "test": "node --test test/core.test.mjs test/package.test.mjs",
    "test:host": "node test/host-functional.mjs",
    "version": "node scripts/sync-plugin-version.mjs mnemo.plugin.json package.json && git add mnemo.plugin.json"
  },
  "devDependencies": {
    "commander": "^14.0.0",
    "esbuild": "^0.27.4",
    "jiti": "^2.6.0",
    "typescript": "^5.9.3"
  }
}
